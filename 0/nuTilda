FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      nuTilda;
}

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 1.5e-5;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 1.5e-5;
    }

    outlet
    {
        type            zeroGradient;
    }

    upperWall
    {
        type            symmetryPlane;
    }

    lowerWall
    {
        type            symmetryPlane;
    }

    NACA4418
    {
        type            fixedValue;
        value           uniform 0;
    }

    front
    {
        type            empty;
    }

    back
    {
        type            empty;
    }
}

